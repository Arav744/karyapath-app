# Copy this file to .env and fill in your real Supabase credentials to
# switch the backend from the local JSON file store to real Postgres.
#
# Where to find these on supabase.com:
#   1. Create a project at https://supabase.com/dashboard
#   2. Go to Project Settings -> API
#   3. Copy "Project URL" -> SUPABASE_URL
#   4. Copy "service_role" secret key -> SUPABASE_SERVICE_KEY
#      (NOT the anon/public key - the server needs the service role key
#      to bypass row-level security, since auth is handled by this app's
#      own login system, not Supabase Auth)
#
# Then run the schema in server/data/schema.sql against your project
# (Supabase dashboard -> SQL Editor -> paste the file -> Run) before
# starting the server, so the tables exist.
#
# Leave both blank to keep running on the local JSON file store - the
# app works identically either way, since both implement the same
# storage interface (see server/lib/store-local.js and store-supabase.js).

SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Port the Express server listens on
PORT=4000
